# ================================
# AfriAds Platform - Frontend Configuration
# ================================

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api
# Production example:
# REACT_APP_API_URL=https://afriads-backend.onrender.com/api
REACT_APP_API_TIMEOUT=30000

# Application Environment
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_DARK_MODE=false
REACT_APP_ENABLE_NOTIFICATIONS=true

# Analytics (Optional)
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_MIXPANEL_TOKEN=

# Ad Preview Configuration
REACT_APP_AD_PREVIEW_TIMEOUT=5000
REACT_APP_MAX_FILE_UPLOAD_SIZE=5242880

# URLs
REACT_APP_SUPPORT_EMAIL=support@afriads.com
REACT_APP_DOCS_URL=https://docs.afriads.com
