# ================================
# AfriAds Platform - Backend Configuration
# ================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Local Postgres can use DB_* values. Production can use Neon/Render style DATABASE_URL.
DATABASE_URL=
DB_SSL=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=afriads_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key_here
JWT_REFRESH_EXPIRE=30d

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./src/uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4

# CORS Configuration
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Payment Gateway (Stripe - Optional)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# M-Pesa Daraja Sandbox
# Create a sandbox app at https://developer.safaricom.co.ke/
MPESA_ENVIRONMENT=sandbox
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=your_sandbox_consumer_key
MPESA_CONSUMER_SECRET=your_sandbox_consumer_secret
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_PASSKEY=your_sandbox_lipa_na_mpesa_passkey
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
# Must be public for Safaricom callbacks. Example: https://your-ngrok-url.ngrok-free.app/api/payments/mpesa/callback
MPESA_CALLBACK_URL=https://your-public-url/api/payments/mpesa/callback
MPESA_ACCOUNT_REFERENCE_PREFIX=AFRIADS

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@afriads.com

# Application URLs
BASE_URL=http://localhost:5000
FRONTEND_BASE_URL=http://localhost:3000

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=your_session_secret_here

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# Ad Serving Configuration
AD_SERVE_TIMEOUT=500
MAX_ADS_PER_REQUEST=10
DEFAULT_AD_TTL=3600

# Analytics
ANALYTICS_BATCH_SIZE=1000
ANALYTICS_FLUSH_INTERVAL=60000
